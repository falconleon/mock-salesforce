# LLM providers for data generation (at least one required for generate command)
ZAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://localhost:11434

# Mock server config
PORT=8080
AUTH_ENABLED=true
MOCK_CLIENT_ID=mock-client-id
MOCK_CLIENT_SECRET=mock-client-secret
MOCK_USERNAME=demo@falcon.local
MOCK_PASSWORD=demo123
MOCK_USERS=analyst@falcon.local:analyst-pass,operator@falcon.local:operator-pass,manager@falcon.local:manager-pass
# Allowlist of OAuth redirect_uri values for the authorization_code flow.
# Unset → defaults to sf CLI (1717/OauthRedirect) + mock /callback.
# Set empty to disable (permissive; logs a startup WARN).
# MOCK_REDIRECT_URIS=http://localhost:1717/OauthRedirect,http://nginx.falcon-backend.orb.local/oauth/callback
SESSION_SECRET=sf-mock-dev-secret
SEED_DATA_PATH=./testdata/seed
API_VERSION=v66.0
INSTANCE_URL=http://localhost:8080
